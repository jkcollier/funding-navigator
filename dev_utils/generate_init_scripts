#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_FILE="$PROJECT_ROOT/.env"
INIT_DIR="$PROJECT_ROOT/init-scripts"

load_env() {
  local env_file="$1"
  while IFS= read -r line || [[ -n "$line" ]]; do
    line=${line%$''}
    [[ -z "$line" ]] && continue
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    if [[ "$line" != *=* ]]; then
      continue
    fi
    local key=${line%%=*}
    local value=${line#*=}
    key=${key//[$'	
 ']}
    if [[ -z "$key" ]]; then
      continue
    fi
    export "$key=$value"
  done < "$env_file"
}

if [[ ! -f "$ENV_FILE" ]]; then
  echo "ERROR: Missing .env at $ENV_FILE" >&2
  exit 1
fi

load_env "$ENV_FILE"

: "${POSTGRES_DB:?POSTGRES_DB must be set in .env}"
: "${POSTGRES_USER:?POSTGRES_USER must be set in .env}"
: "${POSTGRES_PASSWORD:?POSTGRES_PASSWORD must be set in .env}"

if command -v docker >/dev/null 2>&1; then
  COMPOSE_CMD=(docker compose)
elif command -v docker-compose >/dev/null 2>&1; then
  COMPOSE_CMD=(docker-compose)
else
  echo "ERROR: docker compose or docker-compose is required to generate init scripts." >&2
  exit 1
fi

mkdir -p "$INIT_DIR"

SCHEMA_FILE="$INIT_DIR/01-${POSTGRES_DB}_schema.sql"
DATA_FILE="$INIT_DIR/02-${POSTGRES_DB}_data.sql"
RESTORE_FILE="$INIT_DIR/restore_${POSTGRES_DB}.sh"

TMP_SCHEMA="$SCHEMA_FILE.tmp"
TMP_DATA="$DATA_FILE.tmp"

cleanup() {
  rm -f "$TMP_SCHEMA" "$TMP_DATA"
}
trap cleanup EXIT

echo "Generating PostgreSQL init scripts for database: $POSTGRES_DB"
echo

echo "Creating schema dump..."
"${COMPOSE_CMD[@]}" exec -T db env PGPASSWORD="$POSTGRES_PASSWORD"   pg_dump   -U "$POSTGRES_USER"   -d "$POSTGRES_DB"   --schema-only   --no-owner   --no-privileges   --clean   --if-exists   > "$TMP_SCHEMA"

cat > "$SCHEMA_FILE" <<EOF
-- ============================================================================
-- ${POSTGRES_DB} schema
-- ============================================================================
-- Structure only. Auto-generated by dev_utils/generate_init_scripts
-- Regenerate from the current database state when schema changes.
-- ============================================================================

EOF
cat "$TMP_SCHEMA" >> "$SCHEMA_FILE"

echo "  ✓ Created $(basename "$SCHEMA_FILE")"

echo "Creating full data dump..."
"${COMPOSE_CMD[@]}" exec -T db env PGPASSWORD="$POSTGRES_PASSWORD"   pg_dump   -U "$POSTGRES_USER"   -d "$POSTGRES_DB"   --data-only   --no-owner   --no-privileges   --inserts   --column-inserts   > "$TMP_DATA"

cat > "$DATA_FILE" <<EOF
-- ============================================================================
-- ${POSTGRES_DB} data
-- ============================================================================
-- All table data. Auto-generated by dev_utils/generate_init_scripts
-- This file is intended to be restored after the matching schema file.
-- ============================================================================

BEGIN;
SET client_encoding = 'UTF8';
SET session_replication_role = replica;

EOF
cat "$TMP_DATA" >> "$DATA_FILE"
cat >> "$DATA_FILE" <<'EOF'

SET session_replication_role = DEFAULT;
COMMIT;
EOF

echo "  ✓ Created $(basename "$DATA_FILE")"

cat > "$RESTORE_FILE" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_FILE="$PROJECT_ROOT/.env"

load_env() {
  local env_file="$1"
  while IFS= read -r line || [[ -n "$line" ]]; do
    line=${line%$''}
    [[ -z "$line" ]] && continue
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    if [[ "$line" != *=* ]]; then
      continue
    fi
    local key=${line%%=*}
    local value=${line#*=}
    key=${key//[$'	
 ']}
    if [[ -z "$key" ]]; then
      continue
    fi
    export "$key=$value"
  done < "$env_file"
}

if [[ ! -f "$ENV_FILE" ]]; then
  echo "ERROR: Missing .env at $ENV_FILE" >&2
  exit 1
fi

load_env "$ENV_FILE"

: "${POSTGRES_DB:?POSTGRES_DB must be set in .env}"
: "${POSTGRES_USER:?POSTGRES_USER must be set in .env}"
: "${POSTGRES_PASSWORD:?POSTGRES_PASSWORD must be set in .env}"

if command -v docker >/dev/null 2>&1; then
  COMPOSE_CMD=(docker compose)
elif command -v docker-compose >/dev/null 2>&1; then
  COMPOSE_CMD=(docker-compose)
else
  echo "ERROR: docker compose or docker-compose is required to restore init scripts." >&2
  exit 1
fi

SCHEMA_FILE="$SCRIPT_DIR/01-${POSTGRES_DB}_schema.sql"
DATA_FILE="$SCRIPT_DIR/02-${POSTGRES_DB}_data.sql"

if [[ ! -f "$SCHEMA_FILE" || ! -f "$DATA_FILE" ]]; then
  echo "ERROR: Expected dump files not found in $SCRIPT_DIR" >&2
  exit 1
fi

echo "Restoring schema from $(basename "$SCHEMA_FILE")..."
cat "$SCHEMA_FILE" | "${COMPOSE_CMD[@]}" exec -T db env PGPASSWORD="$POSTGRES_PASSWORD"   psql -v ON_ERROR_STOP=1 -U "$POSTGRES_USER" -d "$POSTGRES_DB"

echo "Restoring data from $(basename "$DATA_FILE")..."
cat "$DATA_FILE" | "${COMPOSE_CMD[@]}" exec -T db env PGPASSWORD="$POSTGRES_PASSWORD"   psql -v ON_ERROR_STOP=1 -U "$POSTGRES_USER" -d "$POSTGRES_DB"

echo "Restore complete."
EOF

chmod +x "$RESTORE_FILE"

echo "  ✓ Created $(basename "$RESTORE_FILE")"
echo

echo "All init scripts generated successfully."
echo "Files created:"
echo "  - $SCHEMA_FILE"
echo "  - $DATA_FILE"
echo "  - $RESTORE_FILE"
echo

echo "To regenerate from the running database:"
echo "  ./dev_utils/generate_init_scripts"
echo

echo "To restore on a new machine after the stack is up:"
echo "  ./init-scripts/restore_${POSTGRES_DB}.sh"
